APP_ENV=local
LOG_LEVEL=INFO

# ── Microsoft Foundry Agent Service ───────────────────────────────
# Leave FOUNDRY_PROJECT_ENDPOINT empty to run in MOCK mode (no Azure needed).
# Endpoint form: https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=
# Deployment name of a chat model in your Foundry project.
FOUNDRY_MODEL_NAME=gpt-4o
# Friendly name for the hosted agent (shows up in the Foundry portal).
FOUNDRY_AGENT_NAME=claims-intake-agent
